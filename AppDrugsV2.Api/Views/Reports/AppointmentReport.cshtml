@model List<AppDrugsV2.Application.Features.Reports.DTOs.AppointmentReportDto>
@{
    Layout = null;
    var totalTurnos = Model.Count;
    var entregados = Model.Count(a => a.Estado == "Entregado");
    var cancelados = Model.Count(a => a.Estado == "Cancelado");
    var enProceso = Model.Count(a => a.Estado == "EnProceso");
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Reporte de Turnos — AppDrugsV2</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            font-size: 11px;
            color: #1a1a2e;
            background: #fff;
        }

        /* ── ENCABEZADO ── */
        .header {
            background: linear-gradient(135deg, #1E3A5F 0%, #2563EB 100%);
            color: white;
            padding: 20px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .header-left h1 {
            font-size: 20px;
            font-weight: 700;
            letter-spacing: 0.5px;
        }
        .header-left p {
            font-size: 11px;
            opacity: 0.85;
            margin-top: 4px;
        }
        .header-right {
            text-align: right;
            font-size: 10px;
            opacity: 0.9;
        }

        /* ── RESUMEN ── */
        .summary {
            display: flex;
            gap: 16px;
            padding: 14px 30px;
            background: #F0F4FA;
            border-bottom: 2px solid #2563EB;
        }
        .stat-box {
            flex: 1;
            background: white;
            border-radius: 6px;
            padding: 10px 14px;
            border-left: 4px solid #2563EB;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }
        .stat-box .value {
            font-size: 22px;
            font-weight: 700;
            color: #1E3A5F;
        }
        .stat-box .label {
            font-size: 9px;
            color: #6B7280;
            margin-top: 2px;
        }
        .stat-box.green { border-left-color: #10B981; }
        .stat-box.green .value { color: #065F46; }
        .stat-box.yellow { border-left-color: #F59E0B; }
        .stat-box.yellow .value { color: #92400E; }
        .stat-box.red { border-left-color: #EF4444; }
        .stat-box.red .value { color: #991B1B; }

        /* ── TABLA ── */
        .content { padding: 16px 30px; }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 10px;
        }
        thead tr {
            background: #1E3A5F;
            color: white;
        }
        thead th {
            padding: 9px 8px;
            text-align: left;
            font-weight: 600;
            font-size: 10px;
            letter-spacing: 0.3px;
            border-right: 1px solid rgba(255,255,255,0.15);
        }
        tbody tr:nth-child(even) { background: #F0F4FA; }
        tbody tr:hover { background: #DBEAFE; }
        tbody td {
            padding: 7px 8px;
            border-bottom: 1px solid #E5E7EB;
            vertical-align: top;
        }

        /* ── BADGES ── */
        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 9px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }
        .badge-Recibido  { background: #DBEAFE; color: #1D4ED8; }
        .badge-EnProceso { background: #FEF3C7; color: #92400E; }
        .badge-Entregado { background: #D1FAE5; color: #065F46; }
        .badge-Cancelado { background: #FEE2E2; color: #991B1B; }

        /* ── PIE ── */
        .footer {
            margin-top: 20px;
            padding: 12px 30px;
            background: #F9FAFB;
            border-top: 1px solid #E5E7EB;
            display: flex;
            justify-content: space-between;
            font-size: 9px;
            color: #9CA3AF;
        }
        .footer strong { color: #6B7280; }
    </style>
</head>
<body>

    <!-- ENCABEZADO -->
    <div class="header">
        <div class="header-left">
            <h1>📋 Reporte de Turnos</h1>
            <p>AppDrugsV2 — Sistema de Gestión Farmacéutica</p>
        </div>
        <div class="header-right">
            <div>Generado: <strong>@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</strong></div>
            <div style="margin-top:4px;">Total registros: <strong>@totalTurnos</strong></div>
        </div>
    </div>

    <!-- RESUMEN ESTADÍSTICO -->
    <div class="summary">
        <div class="stat-box">
            <div class="value">@totalTurnos</div>
            <div class="label">TOTAL TURNOS</div>
        </div>
        <div class="stat-box green">
            <div class="value">@entregados</div>
            <div class="label">ENTREGADOS</div>
        </div>
        <div class="stat-box yellow">
            <div class="value">@enProceso</div>
            <div class="label">EN PROCESO</div>
        </div>
        <div class="stat-box red">
            <div class="value">@cancelados</div>
            <div class="label">CANCELADOS</div>
        </div>
    </div>

    <!-- TABLA -->
    <div class="content">
        <table>
            <thead>
                <tr>
                    <th style="width:40px">N°</th>
                    <th>Usuario</th>
                    <th>Sede</th>
                    <th style="width:80px">Estado</th>
                    <th style="width:90px">Fecha Creación</th>
                    <th style="width:90px">Fecha Entrega</th>
                    <th>Medicamentos</th>
                    <th style="width:80px">Archivo</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="font-weight:600;color:#2563EB">@item.Id</td>
                        <td>@item.NombreUsuario</td>
                        <td>@item.Sede</td>
                        <td>
                            <span class="badge badge-@item.Estado">@item.Estado</span>
                        </td>
                        <td>@item.FechaCreacion.ToString("dd/MM/yy HH:mm")</td>
                        <td>
                            @(item.FechaEntrega.HasValue
                                ? item.FechaEntrega.Value.ToString("dd/MM/yy HH:mm")
                                : "—")
                        </td>
                        <td style="max-width:200px">@item.MedicamentosTexto</td>
                        <td>@(item.ArchivoAdjunto ?? "—")</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" style="text-align:center;padding:20px;color:#9CA3AF">
                            No hay turnos para mostrar con los filtros seleccionados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- PIE DE PÁGINA -->
    <div class="footer">
        <span><strong>AppDrugsV2</strong> — Sistema de Gestión Farmacéutica</span>
        <span>Documento generado automáticamente el @DateTime.Now.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-ES"))</span>
        <span>Confidencial — Solo para uso interno</span>
    </div>

</body>
</html>
