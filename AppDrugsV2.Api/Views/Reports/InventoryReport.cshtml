@model List<AppDrugsV2.Application.Features.Reports.DTOs.InventoryReportDto>
@{
    Layout = null;
    var total = Model.Count;
    var sinStock = Model.Count(i => i.Stock == 0);
    var stockBajo = Model.Count(i => i.Stock > 0 && i.Stock < 10);
    var disponible = Model.Count(i => i.Stock >= 10);
    var totalUnidades = Model.Sum(i => i.Stock);
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Reporte de Inventario — AppDrugsV2</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            font-size: 11px;
            color: #1a1a2e;
            background: #fff;
        }

        /* ── ENCABEZADO ── */
        .header {
            background: linear-gradient(135deg, #064E3B 0%, #10B981 100%);
            color: white;
            padding: 20px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .header-left h1 { font-size: 20px; font-weight: 700; }
        .header-left p  { font-size: 11px; opacity: 0.85; margin-top: 4px; }
        .header-right   { text-align: right; font-size: 10px; opacity: 0.9; }

        /* ── RESUMEN ── */
        .summary {
            display: flex;
            gap: 16px;
            padding: 14px 30px;
            background: #F0FDF4;
            border-bottom: 2px solid #10B981;
        }
        .stat-box {
            flex: 1;
            background: white;
            border-radius: 6px;
            padding: 10px 14px;
            border-left: 4px solid #10B981;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }
        .stat-box .value { font-size: 22px; font-weight: 700; color: #064E3B; }
        .stat-box .label { font-size: 9px; color: #6B7280; margin-top: 2px; }
        .stat-box.red   { border-left-color: #EF4444; }
        .stat-box.red   .value { color: #991B1B; }
        .stat-box.yellow{ border-left-color: #F59E0B; }
        .stat-box.yellow .value { color: #92400E; }
        .stat-box.blue  { border-left-color: #3B82F6; }
        .stat-box.blue  .value { color: #1D4ED8; }

        /* ── TABLA ── */
        .content { padding: 16px 30px; }
        table { width: 100%; border-collapse: collapse; font-size: 10px; }
        thead tr { background: #064E3B; color: white; }
        thead th {
            padding: 9px 8px;
            text-align: left;
            font-weight: 600;
            font-size: 10px;
            border-right: 1px solid rgba(255,255,255,0.15);
        }
        tbody tr:nth-child(even) { background: #F0FDF4; }
        tbody td {
            padding: 7px 8px;
            border-bottom: 1px solid #E5E7EB;
            vertical-align: middle;
        }

        /* ── BADGES STOCK ── */
        .badge-stock {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 9px;
            font-weight: 600;
        }
        .badge-ok     { background: #D1FAE5; color: #065F46; }
        .badge-low    { background: #FEF3C7; color: #92400E; }
        .badge-empty  { background: #FEE2E2; color: #991B1B; }
        .badge-active { background: #DBEAFE; color: #1D4ED8; }
        .badge-inactive { background: #F3F4F6; color: #6B7280; }

        /* Stock numérico coloreado */
        .stock-ok    { color: #065F46; font-weight: 700; }
        .stock-low   { color: #92400E; font-weight: 700; }
        .stock-empty { color: #991B1B; font-weight: 700; }

        /* ── PIE ── */
        .footer {
            margin-top: 20px;
            padding: 12px 30px;
            background: #F9FAFB;
            border-top: 1px solid #E5E7EB;
            display: flex;
            justify-content: space-between;
            font-size: 9px;
            color: #9CA3AF;
        }
        .footer strong { color: #6B7280; }
    </style>
</head>
<body>

    <div class="header">
        <div class="header-left">
            <h1>📦 Reporte de Inventario</h1>
            <p>AppDrugsV2 — Sistema de Gestión Farmacéutica</p>
        </div>
        <div class="header-right">
            <div>Generado: <strong>@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</strong></div>
            <div style="margin-top:4px;">Total registros: <strong>@total</strong></div>
        </div>
    </div>

    <div class="summary">
        <div class="stat-box">
            <div class="value">@total</div>
            <div class="label">TOTAL ITEMS</div>
        </div>
        <div class="stat-box blue">
            <div class="value">@totalUnidades</div>
            <div class="label">UNIDADES TOTALES</div>
        </div>
        <div class="stat-box yellow">
            <div class="value">@stockBajo</div>
            <div class="label">STOCK BAJO (&lt;10)</div>
        </div>
        <div class="stat-box red">
            <div class="value">@sinStock</div>
            <div class="label">SIN STOCK</div>
        </div>
    </div>

    <div class="content">
        <table>
            <thead>
                <tr>
                    <th style="width:40px">N°</th>
                    <th>Medicamento</th>
                    <th>Sede</th>
                    <th style="width:60px;text-align:center">Stock</th>
                    <th style="width:90px">Estado Stock</th>
                    <th style="width:80px">Registro</th>
                    <th style="width:100px">Últ. Actualización</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var stockClass = item.Stock == 0 ? "stock-empty"
                                   : item.Stock < 10  ? "stock-low"
                                                      : "stock-ok";
                    var badgeClass = item.Stock == 0 ? "badge-empty"
                                   : item.Stock < 10  ? "badge-low"
                                                      : "badge-ok";
                    <tr>
                        <td style="font-weight:600;color:#10B981">@item.Id</td>
                        <td style="font-weight:500">@item.Medicamento</td>
                        <td>@item.Sede</td>
                        <td style="text-align:center">
                            <span class="@stockClass">@item.Stock</span>
                        </td>
                        <td>
                            <span class="badge-stock @badgeClass">@item.EstadoStock</span>
                        </td>
                        <td>
                            <span class="badge-stock @(item.Activo ? "badge-active" : "badge-inactive")">
                                @item.EstadoTexto
                            </span>
                        </td>
                        <td>
                            @(item.FechaActualizacion.HasValue
                                ? item.FechaActualizacion.Value.ToString("dd/MM/yy HH:mm")
                                : "—")
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align:center;padding:20px;color:#9CA3AF">
                            No hay registros de inventario con los filtros seleccionados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="footer">
        <span><strong>AppDrugsV2</strong> — Sistema de Gestión Farmacéutica</span>
        <span>Generado el @DateTime.Now.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-ES"))</span>
        <span>Confidencial — Solo para uso interno</span>
    </div>

</body>
</html>
